<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF5F7FA">

    <FrameLayout
        android:id="@+id/paw_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:paddingLeft="40dp"
        android:paddingRight="40dp">

        <!-- Left: Temperature area -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Temperature -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top">

                <TextView
                    android:id="@+id/temperature"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="240sp"
                    android:textColor="#FF1A1A2E"
                    android:fontFamily="sans-serif-thin"
                    android:includeFontPadding="false" />

                <TextView
                    android:id="@+id/temp_unit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="°C"
                    android:textSize="64sp"
                    android:textColor="#FF636E7B"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="32dp" />
            </LinearLayout>

            <!-- AC set temp info -->
            <TextView
                android:id="@+id/ac_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="26sp"
                android:textColor="#FF636E7B"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:layout_marginTop="4dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Right: Message + status area -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Settings button (top-right) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/settings_btn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:src="@drawable/ic_settings"
                    android:padding="4dp"
                    android:background="?android:selectableItemBackgroundBorderless" />
            </RelativeLayout>

            <!-- Avatar + Message -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/avatar"
                    android:layout_width="wrap_content"
                    android:layout_height="280dp"
                    android:src="@drawable/avatar_paw"
                    android:scaleType="fitCenter"
                    android:adjustViewBounds="true"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="44sp"
                    android:textColor="#FF1A1A2E"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/sub_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="26sp"
                    android:textColor="#FF636E7B"
                    android:fontFamily="sans-serif"
                    android:gravity="center" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Status bar (full width, bottom) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_gravity="bottom"
        android:paddingBottom="16dp"
        android:paddingTop="8dp">

        <View
            android:id="@+id/status_dot"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:background="@drawable/status_dot"
            android:layout_marginEnd="10dp" />

        <TextView
            android:id="@+id/status_ac"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="32sp"
            android:textColor="#FF636E7B"
            android:fontFamily="sans-serif-medium" />

        <View
            android:layout_width="1dp"
            android:layout_height="32dp"
            android:background="#20000000"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp" />

        <TextView
            android:id="@+id/status_doors"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="32sp"
            android:textColor="#FF636E7B"
            android:fontFamily="sans-serif-medium" />

        <View
            android:layout_width="1dp"
            android:layout_height="32dp"
            android:background="#20000000"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp" />

        <TextView
            android:id="@+id/status_battery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="32sp"
            android:textColor="#FF636E7B"
            android:fontFamily="sans-serif-medium"
            android:visibility="gone" />

        <View
            android:id="@+id/battery_divider"
            android:layout_width="1dp"
            android:layout_height="32dp"
            android:background="#20000000"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/status_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="32sp"
            android:textColor="#FF636E7B"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>
    <TextView
        android:id="@+id/safety_alert"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/alert_ac_off"
        android:textSize="36sp"
        android:textColor="#FFFFFFFF"
        android:background="#FFE74C3C"
        android:gravity="center"
        android:padding="16dp"
        android:fontFamily="sans-serif-bold"
        android:layout_gravity="top"
        android:visibility="gone" />

</FrameLayout>
